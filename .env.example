# ============================================================
# SLAHEALTH ClinicalReview Generator — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored; this file (.env.example) is NOT.
#
# After deployment, register the Telegram webhook once:
#
#   curl "https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/setWebhook" \
#     -d "url=https://your-app.vercel.app/api/automation/telegram" \
#     -d "secret_token=<TELEGRAM_WEBHOOK_SECRET>"
# ============================================================


# ------------------------------------------------------------
# Authentication
# ------------------------------------------------------------

# Secret used to sign review JWT tokens and automation approval JWT tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=


# ------------------------------------------------------------
# Email (Resend)
# ------------------------------------------------------------

# Resend API key for sending transactional emails.
# Obtain at: https://resend.com/api-keys
RESEND_API_KEY=

# From address used for all outbound emails (must be a verified Resend domain).
RESEND_FROM_EMAIL=


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Fully-qualified public URL of the deployed app (no trailing slash).
# Example: https://slahealth.vercel.app
NEXT_PUBLIC_APP_URL=


# ------------------------------------------------------------
# GitHub
# ------------------------------------------------------------

# GitHub personal access token with repo read/write access.
# Used for content storage and source document fetching.
# Obtain at: https://github.com/settings/tokens
GITHUB_TOKEN=


# ------------------------------------------------------------
# Vercel KV (Upstash Redis)
# ------------------------------------------------------------

# REST API URL for the Vercel KV store.
# Found in: Vercel dashboard → Storage → KV → .env.local
KV_REST_API_URL=

# REST API token for the Vercel KV store.
KV_REST_API_TOKEN=

# Full connection URL used by the @vercel/kv SDK.
KV_URL=


# ------------------------------------------------------------
# Telegram (Automation Module)
# ------------------------------------------------------------

# Telegram Bot API token issued by @BotFather (format: bot<token>).
# Create a bot at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Random 32-character secret used to verify incoming Telegram webhook requests.
# Generate with: openssl rand -hex 16
TELEGRAM_WEBHOOK_SECRET=
